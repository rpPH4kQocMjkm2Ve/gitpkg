#!/bin/bash
# gitpkg — minimal package manager for git + make projects
#
# All build/install steps run sandboxed via bubblewrap.
# Tracks installed files via DESTDIR staging.
# Resolves packages from configured base URLs (repo-agnostic).
# Supports monorepo collections: a single git repo with multiple packages as subdirectories.

set -euo pipefail
export GIT_TERMINAL_PROMPT=0

readonly LIBDIR="/usr/lib/gitpkg"
_src() { local p; p=$(verify-lib "$1" "$LIBDIR/") && source "$p" || exit 1; }

_src "${LIBDIR}/common.sh"
_src "${LIBDIR}/sandbox.sh"
_src "${LIBDIR}/package.sh"

# ── Help ──────────────────────────────────────────────────

show_help() {
    cat << EOF
gitpkg v${VERSION} — git + make package manager

Usage: gitpkg <command> [options] [args]

Commands:
    install  <name> [name...]           Clone, build, install
    update   [name...]                    Update one, many, or all packages
    remove   <name>                     Uninstall and remove source
    list                                List installed packages
    status                              Check for upstream updates
    files    <name>                     List tracked files
    inspect  <name> [url]               Show Makefile before installing
    verify   [name]                     Check system dirs or package integrity
    repo-add  <base_url>                Add a package source
    repo-del  <base_url>                Remove a package source
    repo-list                           List configured sources
    collection-add <name>               Register a collection repository
    collection-del <name>               Unregister a collection repository
    collection-list                     List configured collections
    signer-add <principal> <pubkey>     Add a trusted signing key
    signer-del <principal>              Remove a trusted signing key
    signer-list                         List trusted signing keys
    search    <query>                   Search known packages

Options:
    -n, --dry-run    Show what would be done (install, update, remove)
    -y, --yes        Skip confirmation (remove)
    --fix            Auto-repair permission anomalies (verify)
    --skip-inspect   Skip Makefile review (install, update)
    --needed         Do not reinstall up to date packages
    --nodeps         Skip dependency check (install, update, remove)
    --nosig          Skip commit signature verification (install, update)
    -h, --help       Show this help
    -V, --version    Show version

Environment:
    GITPKG_CLONE_TIMEOUT     Clone timeout in seconds (default: 120)
    GITPKG_FETCH_TIMEOUT     Fetch timeout in seconds (default: 30)
    GITPKG_LSREMOTE_TIMEOUT  Status check timeout in seconds (default: 15)

Security:
    Build and install steps run inside a bubblewrap sandbox with
    PID/UTS/IPC namespaces isolated, system dirs read-only.
    DESTDIR is enforced at filesystem level — installed files are
    staged, validated, then deployed. Always review the Makefile.

    Signatures:
        If /etc/gitpkg/allowed_signers or signers.conf contains SSH public
        keys, gitpkg requires valid commit signatures for install/update.
        Unsigned or untrusted commits are rejected.
        Use --nosig to bypass signature verification.

Collections:
    A collection is a single git repository containing multiple packages
    as subdirectories, each with its own Makefile. Default collections are
    listed in /etc/gitpkg/collections. User collections can be added with
    'gitpkg collection-add <name>'. When installing a package, gitpkg
    first tries standalone repos, then searches all collections.

EOF
    exit 0
}

# ── Commands ──────────────────────────────────────────────

cmd_inspect() {
    local name="${1:-}"
    local url="${2:-}"

    [[ -n "$name" ]] || die "usage: gitpkg inspect <name> [url]"

    # Check if installed from a collection
    local dbdir="${DBDIR}/${name}"
    if [[ -d "$dbdir" && -f "${dbdir}/collection" ]]; then
        local coll
        coll=$(cat "${dbdir}/collection")
        local colldir="${COLLECTIONSDIR}/${coll}"
        if [[ -f "${colldir}/${name}/Makefile" ]]; then
            _show_makefile "${colldir}/${name}/Makefile"
            return
        fi
    fi

    # Check standalone source cache
    local srcdir="${SRCDIR}/${name}"
    if [[ -d "$srcdir" ]]; then
        [[ -r "${srcdir}/Makefile" ]] || die "${srcdir}/Makefile is not readable"
        _show_makefile "${srcdir}/Makefile"
        return
    fi

    # Check cached collections (no network)
    if _find_in_collections "$name" 0; then
        _show_makefile "${_FOUND_WORKDIR}/Makefile"
        return
    fi

    # Try remote clone
    local -a clone_urls=()
    if [[ -n "$url" ]]; then
        clone_urls+=("$url")
    else
        mapfile -t clone_urls < <(_resolve_urls "$name")
        [[ ${#clone_urls[@]} -gt 0 ]] || \
            die "no sources for '${name}'. Specify URL or run 'gitpkg repo-add <base_url>'."
    fi

    local tmpdir
    tmpdir=$(mktemp -d /tmp/gitpkg-inspect.XXXXXX)

    local cloned=0 u
    for u in "${clone_urls[@]}"; do
        printf '   Fetching %s ... ' "$u"
        if timeout "$CLONE_TIMEOUT" git clone --filter=blob:none --depth=1 "$u" "${tmpdir}/repo" &>/dev/null; then
            echo "ok"
            cloned=1
            break
        fi
        echo "fail"
        rm -rf "${tmpdir}/repo"
    done

    if [[ $cloned -eq 1 && -f "${tmpdir}/repo/Makefile" ]]; then
        _show_makefile "${tmpdir}/repo/Makefile"
        rm -rf "$tmpdir"
        return
    fi

    # Try fetching collections to find the Makefile
    if _find_in_collections "$name" 1; then
        _show_makefile "${_FOUND_WORKDIR}/Makefile"
        rm -rf "$tmpdir"
        return
    fi

    rm -rf "$tmpdir"
    die "no Makefile found for ${name}"
}

cmd_install() {
    local dry_run="$1"; shift
    local skip_inspect="$1"; shift
    local needed="$1"; shift
    local nodeps="$1"; shift
    local nosig="$1"; shift

    [[ $# -gt 0 ]] || die "usage: gitpkg install <name>... [--needed] [--skip-inspect] [-n]"
    [[ $EUID -eq 0 ]] || die "must run as root"

    _check_deps
    acquire_lock

    local name
    for name in "$@"; do
        _install_single "$name" "$dry_run" "$skip_inspect" "$needed" "$nodeps" "$nosig"
    done
}

_install_single() {
    local name="$1"
    local dry_run="$2"
    local skip_inspect="$3"
    local needed="$4"
    local nodeps="$5"
    local nosig="$6"

    local dbdir="${DBDIR}/${name}"
    local srcdir="${SRCDIR}/${name}"

    if _is_system_managed "$name"; then
        printf 'ERROR: %s is managed by the system package manager — skipping\n' "$name" >&2
        printf '  Use your system package manager to manage this package.\n' >&2
        return 1
    fi

    if [[ -d "$dbdir" ]]; then
        if [[ "$needed" -eq 1 ]]; then
            printf '%s is up to date -- skipping\n' "$name"
            return
        fi
        printf 'warning: %s is up to date -- reinstalling\n' "$name"
        _remove_tracked "$name"
        # Preserve backup checksums for config file handling across reinstall
        local _saved_bkp_chk=""
        [[ -f "${dbdir}/backup_checksums" ]] && _saved_bkp_chk=$(cat "${dbdir}/backup_checksums")
        rm -rf "$dbdir"
        if [[ -n "$_saved_bkp_chk" ]]; then
            mkdir -p "$dbdir"
            printf '%s\n' "$_saved_bkp_chk" > "${dbdir}/backup_checksums"
        fi
    fi

    local -a clone_urls=()
    mapfile -t clone_urls < <(_resolve_urls "$name")

    printf ':: Installing %s...\n' "$name"

    local workdir=""
    local gitdir=""
    local collection=""
    local from_collection=0

    if [[ -d "$srcdir" ]]; then
        local branch
        branch=$(git -C "$srcdir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
        timeout "$FETCH_TIMEOUT" git -C "$srcdir" fetch origin "$branch" &>/dev/null || true
        git -C "$srcdir" reset --hard "origin/${branch}" &>/dev/null || true
        workdir="$srcdir"
        gitdir="$srcdir"
    elif [[ ${#clone_urls[@]} -gt 0 ]]; then
        CLONE_SUCCESS_URL=""
        if _clone "$name" "${clone_urls[@]}"; then
            workdir="$srcdir"
            gitdir="$srcdir"
        fi
    fi

    # Standalone succeeded but no Makefile — discard and try collections
    if [[ -n "$workdir" && ! -f "${workdir}/Makefile" ]]; then
        rm -rf "$srcdir"
        workdir=""
        gitdir=""
    fi

    # Standalone didn't produce a result — search collections
    if [[ -z "$workdir" ]]; then
        if _find_in_collections "$name"; then
            workdir="$_FOUND_WORKDIR"
            gitdir="$_FOUND_GITDIR"
            collection="$_FOUND_COLLECTION"
            from_collection=1
        fi
    fi

    if [[ -z "$workdir" || ! -f "${workdir}/Makefile" ]]; then
        printf 'ERROR: no Makefile found for %s\n' "$name" >&2
        return 1
    fi

    # ── Signature verification ──
    if [[ "$dry_run" -eq 0 && "$nosig" -eq 0 ]]; then
        if ! _verify_signature "$gitdir"; then
            [[ "$from_collection" -eq 0 && -d "$srcdir" ]] && rm -rf "$srcdir"
            die "unsigned/untrusted commit for ${name} — use --nosig to bypass"
        fi
    fi

    if [[ "$nodeps" -eq 0 && "$dry_run" -eq 0 ]] && ! _check_package_deps "$workdir"; then
        echo ""
        read -rp "   Dependencies missing. Continue anyway? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy] ]]; then
            [[ "$from_collection" -eq 0 && -d "$srcdir" ]] && rm -rf "$srcdir"
            printf 'Skipped %s.\n' "$name"
            return
        fi
    fi

    if [[ "$skip_inspect" -eq 0 && "$dry_run" -eq 0 ]]; then
        echo ""
        printf '── Makefile for %s ─────────────────────────────────\n' "$name"
        _strip_escape_sequences < "${workdir}/Makefile"
        echo "────────────────────────────────────────────────────────────"
        echo ""
        read -rp "Proceed with install of ${name}? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy] ]]; then
            if [[ "$from_collection" -eq 0 ]]; then
                rm -rf "$srcdir"
            fi
            printf 'Skipped %s.\n' "$name"
            return
        fi
    fi

    if _stage_and_deploy "$name" "$dry_run" "$workdir" "$gitdir"; then
        local _origin_url="${CLONE_SUCCESS_URL}"
        if [[ -z "$_origin_url" ]]; then
            _origin_url=$(git -C "$gitdir" remote get-url origin 2>/dev/null || true)
        fi

        mkdir -p "$dbdir"

        if [[ "$from_collection" -eq 1 ]]; then
            # Store collection repo URL and collection marker
            [[ -n "$_origin_url" ]] && echo "$_origin_url" > "${dbdir}/urls"
            echo "$collection" > "${dbdir}/collection"
        else
            # Store standalone URLs
            if [[ -n "$_origin_url" ]]; then
                {
                    echo "$_origin_url"
                    local u
                    for u in "${clone_urls[@]}"; do
                        [[ "$u" != "$_origin_url" ]] && echo "$u"
                    done
                } > "${dbdir}/urls"
            fi
        fi

        local commit
        commit=$(_safe_read_commit "${dbdir}/commit")
        if [[ "$from_collection" -eq 1 ]]; then
            printf 'Installed %s [%s] (collection: %s)\n' "$name" "${commit:0:8}" "$collection"
        else
            printf 'Installed %s [%s]\n' "$name" "${commit:0:8}"
        fi
    else
        if [[ "$from_collection" -eq 0 ]]; then
            rm -rf "${SRCDIR}/${name}"
        fi
        if [[ "$dry_run" -eq 1 ]]; then
            printf 'Dry run complete for %s — nothing was installed.\n' "$name"
        else
            printf 'ERROR: stage/deploy failed for %s\n' "$name" >&2
            return 1
        fi
    fi
}

cmd_update() {
    [[ $EUID -eq 0 ]] || die "must run as root"

    _check_deps
    acquire_lock

    local dry_run="$1"; shift
    local skip_inspect="$1"; shift
    local nodeps="$1"; shift
    local nosig="$1"; shift

    declare -gA _FETCHED_COLLECTIONS=()

    if [[ $# -eq 0 ]]; then
        local found=0
        for d in "${DBDIR}"/*/; do
            [[ -d "$d" ]] || continue
            found=1
            _update_single "$(basename "$d")" "$dry_run" "$skip_inspect" "$nodeps" "$nosig"
        done
        [[ $found -eq 1 ]] || echo "No packages installed."
        return
    fi

    local name
    for name in "$@"; do
        _update_single "$name" "$dry_run" "$skip_inspect" "$nodeps" "$nosig"
    done
}

_update_single() {
    local name="$1"
    local dry_run="${2:-0}"
    local skip_inspect="${3:-0}"
    local nodeps="${4:-0}"
    local nosig="${5:-0}"
    local dbdir="${DBDIR}/${name}"

    [[ -d "$dbdir" ]] || die "${name} is not installed"

    local old_commit
    old_commit=$(_safe_read_commit "${dbdir}/commit")

    if _is_system_managed "$name"; then
        printf '%s: managed by system package manager, skipping\n' "$name"
        return
    fi

    # Determine if this is a collection package
    local collection=""
    [[ -f "${dbdir}/collection" ]] && collection=$(cat "${dbdir}/collection")

    if [[ -n "$collection" ]]; then
        _update_collection_package "$name" "$collection" "$old_commit" "$dry_run" "$skip_inspect" "$nodeps" "$nosig"
    else
        _update_standalone_package "$name" "$old_commit" "$dry_run" "$skip_inspect" "$nodeps" "$nosig"
    fi
}

_update_standalone_package() {
    local name="$1"
    local old_commit="$2"
    local dry_run="$3"
    local skip_inspect="$4"
    local nodeps="$5"
    local nosig="$6"
    local srcdir="${SRCDIR}/${name}"
    local dbdir="${DBDIR}/${name}"

    if [[ ! -d "$srcdir" ]]; then
        printf ':: Re-cloning %s (source cache missing)...\n' "$name"
        local -a reclone_urls=()
        mapfile -t reclone_urls < <({
            [[ -f "${dbdir}/urls" ]] && cat "${dbdir}/urls"
            _resolve_urls "$name"
        } | _dedup_urls)
        [[ ${#reclone_urls[@]} -gt 0 ]] || die "no URL recorded for ${name}"
        CLONE_SUCCESS_URL=""
        if ! _clone "$name" "${reclone_urls[@]}"; then
            die "failed to clone ${name}"
        fi
    fi

    local branch
    branch=$(git -C "$srcdir" rev-parse --abbrev-ref HEAD)

    printf ':: Fetching %s...\n' "$name"
    if ! timeout "$FETCH_TIMEOUT" git -C "$srcdir" fetch origin "$branch" &>/dev/null; then
        echo ":: Primary fetch failed, trying fallbacks..."
        local fetched=0
        local -a fb_urls=()
        mapfile -t fb_urls < <({
            [[ -f "${dbdir}/urls" ]] && tail -n +2 "${dbdir}/urls"
            _resolve_urls "$name"
        } | _dedup_urls)

        local u
        for u in "${fb_urls[@]}"; do
            printf '   Trying %s ... ' "$u"
            git -C "$srcdir" remote set-url origin "$u"
            if timeout "$FETCH_TIMEOUT" git -C "$srcdir" fetch origin "$branch" &>/dev/null; then
                echo "ok"
                fetched=1
                break
            fi
            echo "fail"
        done

        [[ $fetched -eq 1 ]] || die "fetch failed for ${name}"
    fi

    local new_commit
    new_commit=$(git -C "$srcdir" rev-parse "origin/${branch}")

    if [[ "$old_commit" == "$new_commit" ]]; then
        printf '%s: up to date [%s]\n' "$name" "${old_commit:0:8}"
        return
    fi

    # ── Signature verification ──
    if [[ "$dry_run" -eq 0 && "$nosig" -eq 0 ]]; then
        if ! _verify_signature "$srcdir" "origin/${branch}"; then
            die "unsigned/untrusted commit for ${name} — use --nosig to bypass"
        fi
    fi

    if [[ "$dry_run" -eq 1 ]]; then
        printf '%s: %s -> %s (would update)\n' "$name" "${old_commit:0:8}" "${new_commit:0:8}"
        return
    fi

    if [[ "$skip_inspect" -eq 0 ]]; then
        local makefile_diff
        makefile_diff=$(git -C "$srcdir" diff "$old_commit" "$new_commit" -- Makefile 2>/dev/null || true)
        if [[ -n "$makefile_diff" ]]; then
            echo ""
            printf '── Makefile changes for %s ──────────────────────────\n' "$name"
            printf '%s\n' "$makefile_diff" | _strip_escape_sequences
            echo "────────────────────────────────────────────────────────────"
            echo ""
            read -rp "Makefile changed. Proceed with update of ${name}? [y/N] " answer
            if [[ ! "$answer" =~ ^[Yy] ]]; then
                printf 'Skipped %s.\n' "$name"
                return
            fi
        fi
    fi

    printf ':: Updating %s [%s -> %s]...\n' "$name" "${old_commit:0:8}" "${new_commit:0:8}"
    git -C "$srcdir" reset --hard "origin/${branch}" &>/dev/null

    if [[ "$nodeps" -eq 0 ]] && ! _check_package_deps "$srcdir"; then
        echo ""
        read -rp "   Dependencies missing. Continue anyway? [y/N] " answer
        [[ "$answer" =~ ^[Yy] ]] || { printf 'Skipped %s.\n' "$name"; return; }
    fi

    _remove_tracked "$name"
    _stage_and_deploy "$name" 0 "$srcdir" "$srcdir"

    printf 'Updated %s\n' "$name"
}

_update_collection_package() {
    local name="$1"
    local collection="$2"
    local old_commit="$3"
    local dry_run="$4"
    local skip_inspect="$5"
    local nodeps="$6"
    local nosig="$7"
    local dbdir="${DBDIR}/${name}"
    local colldir="${COLLECTIONSDIR}/${collection}"

    # Re-clone collection if cache is missing
    if [[ ! -d "$colldir/.git" ]]; then
        printf ':: Re-cloning collection %s (cache missing)...\n' "$collection"
        local -a reclone_urls=()
        mapfile -t reclone_urls < <({
            [[ -f "${dbdir}/urls" ]] && cat "${dbdir}/urls"
            _resolve_urls "$collection"
        } | _dedup_urls)
        [[ ${#reclone_urls[@]} -gt 0 ]] || die "no URL recorded for collection ${collection}"
        CLONE_SUCCESS_URL=""
        if ! _clone_to "$colldir" "${reclone_urls[@]}"; then
            die "failed to clone collection ${collection}"
        fi
    fi

    local branch
    branch=$(git -C "$colldir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")

    # Fetch (deduplicated across batch updates)
    if [[ -z "${_FETCHED_COLLECTIONS[$collection]:-}" ]]; then
        printf ':: Fetching collection %s...\n' "$collection"
        if ! timeout "$FETCH_TIMEOUT" git -C "$colldir" fetch origin "$branch" &>/dev/null; then
            echo ":: Primary fetch failed for collection ${collection}, trying fallbacks..."
            local fetched=0
            local -a fb_urls=()
            mapfile -t fb_urls < <({
                [[ -f "${dbdir}/urls" ]] && cat "${dbdir}/urls"
                _resolve_urls "$collection"
            } | _dedup_urls)

            local u
            for u in "${fb_urls[@]}"; do
                printf '   Trying %s ... ' "$u"
                git -C "$colldir" remote set-url origin "$u"
                if timeout "$FETCH_TIMEOUT" git -C "$colldir" fetch origin "$branch" &>/dev/null; then
                    echo "ok"
                    fetched=1
                    break
                fi
                echo "fail"
            done

            if [[ $fetched -ne 1 ]]; then
                printf 'ERROR: fetch failed for collection %s, skipping %s\n' "$collection" "$name" >&2
                return 1
            fi
        fi
        _FETCHED_COLLECTIONS[$collection]=1
    fi

    local new_commit
    new_commit=$(git -C "$colldir" rev-parse "origin/${branch}")

    if [[ "$old_commit" == "$new_commit" ]]; then
        printf '%s: up to date [%s] (collection: %s)\n' "$name" "${old_commit:0:8}" "$collection"
        return
    fi

    # Check if this specific package's subdirectory changed
    local subdir_diff
    subdir_diff=$(git -C "$colldir" diff --name-only "$old_commit" "$new_commit" -- "${name}/" 2>/dev/null || true)

    if [[ -z "$subdir_diff" ]]; then
        # Collection updated but this package's subdir didn't change — update stored commit
        printf '%s: up to date [%s -> %s] (collection: %s, no subdir changes)\n' \
            "$name" "${old_commit:0:8}" "${new_commit:0:8}" "$collection"
        echo "$new_commit" > "${dbdir}/commit"
        return
    fi

    # ── Signature verification ──
    if [[ "$dry_run" -eq 0 && "$nosig" -eq 0 ]]; then
        if ! _verify_signature "$colldir" "origin/${branch}"; then
            die "unsigned/untrusted commit for ${name} (collection: ${collection}) — use --nosig to bypass"
        fi
    fi

    if [[ "$dry_run" -eq 1 ]]; then
        printf '%s: %s -> %s (would update, collection: %s)\n' "$name" "${old_commit:0:8}" "${new_commit:0:8}" "$collection"
        return
    fi

    if [[ "$skip_inspect" -eq 0 ]]; then
        local makefile_diff
        makefile_diff=$(git -C "$colldir" diff "$old_commit" "$new_commit" -- "${name}/Makefile" 2>/dev/null || true)
        if [[ -n "$makefile_diff" ]]; then
            echo ""
            printf '── Makefile changes for %s ──────────────────────────\n' "$name"
            printf '%s\n' "$makefile_diff" | _strip_escape_sequences
            echo "────────────────────────────────────────────────────────────"
            echo ""
            read -rp "Makefile changed. Proceed with update of ${name}? [y/N] " answer
            if [[ ! "$answer" =~ ^[Yy] ]]; then
                printf 'Skipped %s.\n' "$name"
                return
            fi
        fi
    fi

    printf ':: Updating %s [%s -> %s] (collection: %s)...\n' "$name" "${old_commit:0:8}" "${new_commit:0:8}" "$collection"
    git -C "$colldir" reset --hard "origin/${branch}" &>/dev/null

    local workdir="${colldir}/${name}"
    if [[ ! -f "${workdir}/Makefile" ]]; then
        die "${name}: Makefile disappeared from collection ${collection}"
    fi

    if [[ "$nodeps" -eq 0 ]] && ! _check_package_deps "$workdir"; then
        echo ""
        read -rp "   Dependencies missing. Continue anyway? [y/N] " answer
        [[ "$answer" =~ ^[Yy] ]] || { printf 'Skipped %s.\n' "$name"; return; }
    fi

    _remove_tracked "$name"
    _stage_and_deploy "$name" 0 "$workdir" "$colldir"

    printf 'Updated %s\n' "$name"
}

cmd_remove() {
    local dry_run="$1"; shift
    local yes="$1"; shift
    local nodeps="$1"; shift
    local name="${1:-}"

    [[ -n "$name" ]]            || die "usage: gitpkg remove <name>"
    [[ $EUID -eq 0 ]]           || die "must run as root"
    [[ -d "${DBDIR}/${name}" ]] || die "${name} is not installed"

    if _is_system_managed "$name"; then
        die "${name} is managed by the system package manager. Use your system package manager to remove it."
    fi

    acquire_lock

    # ── Reverse dependency check ──
    local rdeps_confirmed=0
    if [[ "$nodeps" -eq 0 ]]; then
        local -a rdeps=()
        mapfile -t rdeps < <(_check_reverse_deps "$name")
        if [[ ${#rdeps[@]} -gt 0 ]]; then
            printf ':: The following installed packages depend on %s:\n' "$name"
            local _rd
            for _rd in "${rdeps[@]}"; do
                printf '     %s\n' "$_rd"
            done
            echo ""
            printf '   Removing %s may break these packages.\n' "$name"

            if [[ "$dry_run" -eq 1 ]]; then
                printf '   Use --nodeps to skip this check.\n'
                # fall through to dry-run listing below
            else
                read -rp "   Continue anyway? [y/N] " answer
                [[ "$answer" =~ ^[Yy] ]] || { echo "Aborted."; exit 0; }
                rdeps_confirmed=1
            fi
        fi
    fi

    if [[ "$dry_run" -eq 1 ]]; then
        printf 'Would remove %s:\n' "$name"
        local filelist="${DBDIR}/${name}/files"
        local backupfile="${DBDIR}/${name}/backup"
        local -A _preserve=()
        if [[ -f "$backupfile" ]]; then
            while IFS= read -r _line; do
                [[ -z "$_line" || "$_line" == \#* ]] && continue
                _preserve["${_line#/}"]=1
            done < "$backupfile"
        fi
        if [[ -f "$filelist" ]]; then
            while IFS= read -r f; do
                [[ -z "$f" ]] && continue
                if [[ -n "${_preserve[$f]:-}" ]]; then
                    printf '   /%s  (backup — preserved)\n' "$f"
                else
                    printf '   /%s\n' "$f"
                fi
            done < "$filelist"
        fi
        return
    fi

    if [[ "$yes" -eq 0 && "$rdeps_confirmed" -eq 0 ]]; then
        local file_count=0
        [[ -f "${DBDIR}/${name}/files" ]] && file_count=$(wc -l < "${DBDIR}/${name}/files")
        printf 'Will remove %s (%d files)\n' "$name" "$file_count"
        read -rp "Continue? [y/N] " answer
        [[ "$answer" =~ ^[Yy] ]] || { echo "Aborted."; exit 0; }
    fi

    printf ':: Removing %s...\n' "$name"
    _remove_tracked "$name"
    rm -rf "${DBDIR}/${name}"
    # Remove standalone source cache (collection caches are shared, leave them)
    [[ -d "${SRCDIR}/${name}" ]] && rm -rf "${SRCDIR}/${name}"
    printf 'Removed %s\n' "$name"
}

cmd_list() {
    local found=0
    for d in "${DBDIR}"/*/; do
        [[ -d "$d" ]] || continue
        found=1
        local name commit coll_marker=""
        name=$(basename "$d")
        commit=$(_safe_read_commit "${d}commit")
        if [[ -f "${d}collection" ]]; then
            coll_marker=" ($(cat "${d}collection"))"
        fi
        printf '%-28s %s%s\n' "$name" "${commit:0:12}" "$coll_marker"
    done
    [[ $found -eq 1 ]] || echo "No packages installed."
}

cmd_status() {
    STATUS_TMPDIR=$(mktemp -d /tmp/gitpkg-status.XXXXXX)
    local -a pids=() tmpfiles=()
    local found=0
    local running=0

    for d in "${DBDIR}"/*/; do
        [[ -d "$d" ]] || continue
        found=1

        local name commit origin_url coll_marker=""
        name=$(basename "$d")
        commit=$(_safe_read_commit "${d}commit")
        origin_url=""
        [[ -f "${d}urls" ]] && origin_url=$(head -n1 "${d}urls" 2>/dev/null || true)
        [[ -f "${d}collection" ]] && coll_marker=" ($(cat "${d}collection"))"

        local tmp="${STATUS_TMPDIR}/${name}"
        tmpfiles+=("$tmp")

        (
            if [[ -z "$origin_url" ]]; then
                printf '%-28s ? %s%s (no URL recorded)\n' "$name" "${commit:0:12}" "$coll_marker"
            else
                local remote=""
                remote=$(timeout "$LSREMOTE_TIMEOUT" git ls-remote "$origin_url" HEAD 2>/dev/null | awk '{print $1; exit}')
                if [[ -z "$remote" ]]; then
                    printf '%-28s ? %s%s (fetch failed)\n' "$name" "${commit:0:12}" "$coll_marker"
                elif [[ "$commit" == "$remote" ]]; then
                    printf '%-28s ok %s%s\n' "$name" "${commit:0:12}" "$coll_marker"
                else
                    printf '%-28s >> %s -> %s%s\n' "$name" "${commit:0:12}" "${remote:0:12}" "$coll_marker"
                fi
            fi
        ) > "$tmp" &
        pids+=($!)
        running=$((running + 1))

        if [[ $running -ge $MAX_STATUS_PARALLEL ]]; then
            wait "${pids[0]}" 2>/dev/null || true
            cat "${tmpfiles[0]}"
            pids=("${pids[@]:1}")
            tmpfiles=("${tmpfiles[@]:1}")
            running=$((running - 1))
        fi
    done

    local i
    for i in "${!pids[@]}"; do
        wait "${pids[$i]}" 2>/dev/null || true
        cat "${tmpfiles[$i]}"
    done

    rm -rf "$STATUS_TMPDIR"
    STATUS_TMPDIR=""

    [[ $found -eq 1 ]] || echo "No packages installed."
}

cmd_files() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: gitpkg files <name>"

    local filelist="${DBDIR}/${name}/files"
    [[ -f "$filelist" ]] || die "${name} is not installed"

    while IFS= read -r f; do
        [[ -z "$f" ]] && continue
        if [[ -L "/${f}" ]]; then
            printf '/%s -> %s\n' "$f" "$(readlink "/${f}")"
        elif [[ -f "/${f}" ]]; then
            printf '/%s\n' "$f"
        else
            printf '/%s  (missing)\n' "$f"
        fi
    done < "$filelist"
}

cmd_verify() {
    local fix="$1"
    local name="${2:-}"
    [[ $EUID -eq 0 ]] || die "must run as root"

    if [[ -n "$name" ]]; then
        _verify_package "$name"
    else
        _verify_permissions "$fix"
    fi
}

# ── Repository commands ───────────────────────────────────

cmd_repo_add() {
    local url="${1:-}"
    [[ -n "$url" ]] || die "usage: gitpkg repo-add <base_url>"
    [[ $EUID -eq 0 ]] || die "must run as root"

    [[ "$url" =~ ^https?:// ]] || die "invalid URL: ${url}"

    url="${url%/}"

    _ensure_conf

    if grep -qxF "$url" "$REPOS_CONF" 2>/dev/null; then
        die "repository already added: ${url}"
    fi

    if [[ -f "$MIRRORLIST" ]] && grep -qxF "$url" "$MIRRORLIST" 2>/dev/null; then
        die "repository already exists in mirrorlist: ${url}"
    fi

    echo "$url" >> "$REPOS_CONF"
    printf 'Added repository: %s\n' "$url"
}

cmd_repo_del() {
    local url="${1:-}"
    [[ -n "$url" ]] || die "usage: gitpkg repo-del <base_url>"
    [[ $EUID -eq 0 ]] || die "must run as root"

    url="${url%/}"

    _ensure_conf

    if ! grep -qxF "$url" "$REPOS_CONF" 2>/dev/null; then
        die "repository not found: ${url}"
    fi

    local content
    content=$(grep -vxF "$url" "$REPOS_CONF" || true)
    if [[ -n "$content" ]]; then
        printf '%s\n' "$content" > "$REPOS_CONF"
    else
        : > "$REPOS_CONF"
    fi

    printf 'Removed repository: %s\n' "$url"
}

cmd_repo_list() {
    local found=0
    local -A seen=()

    if [[ -f "$REPOS_CONF" ]]; then
        if [[ ! -r "$REPOS_CONF" ]]; then
            printf 'WARN: %s is not readable\n' "$REPOS_CONF" >&2
        else
            while IFS= read -r url; do
                [[ -z "$url" || "$url" == \#* ]] && continue
                url="${url%/}"
                [[ -n "${seen[$url]:-}" ]] && continue
                seen[$url]=1
                found=1
                printf '%-60s [repo]\n' "$url"
            done < "$REPOS_CONF"
        fi
    fi

    if [[ -f "$MIRRORLIST" ]]; then
        if [[ ! -r "$MIRRORLIST" ]]; then
            printf 'WARN: %s is not readable\n' "$MIRRORLIST" >&2
        else
            while IFS= read -r url; do
                [[ -z "$url" || "$url" == \#* ]] && continue
                url="${url%/}"
                [[ -n "${seen[$url]:-}" ]] && continue
                seen[$url]=1
                found=1
                printf '%-60s [mirror]\n' "$url"
            done < "$MIRRORLIST"
        fi
    fi

    [[ $found -eq 1 ]] || echo "No sources configured. Use 'gitpkg repo-add <base_url>'."
}

# ── Collection commands ───────────────────────────────────

cmd_collection_add() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: gitpkg collection-add <name>"
    [[ $EUID -eq 0 ]] || die "must run as root"

    [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || die "invalid collection name: ${name}"

    _ensure_conf

    if [[ -f "$COLLECTIONS_CONF" ]] && grep -qxF "$name" "$COLLECTIONS_CONF" 2>/dev/null; then
        die "collection already added: ${name}"
    fi

    if [[ -f "$COLLECTIONS_LIST" ]] && grep -qxF "$name" "$COLLECTIONS_LIST" 2>/dev/null; then
        die "collection already exists in default list: ${name}"
    fi

    echo "$name" >> "$COLLECTIONS_CONF"
    chmod 644 "$COLLECTIONS_CONF"

    printf 'Added collection: %s\n' "$name"
}

cmd_collection_del() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "usage: gitpkg collection-del <name>"
    [[ $EUID -eq 0 ]] || die "must run as root"

    if [[ -f "$COLLECTIONS_LIST" ]] && grep -qxF "$name" "$COLLECTIONS_LIST" 2>/dev/null; then
        die "cannot remove default collection '${name}' — edit ${COLLECTIONS_LIST} manually"
    fi

    if [[ ! -f "$COLLECTIONS_CONF" ]] || ! grep -qxF "$name" "$COLLECTIONS_CONF" 2>/dev/null; then
        die "collection not registered: ${name}"
    fi

    local content
    content=$(grep -vxF "$name" "$COLLECTIONS_CONF" || true)
    if [[ -n "$content" ]]; then
        printf '%s\n' "$content" > "$COLLECTIONS_CONF"
    else
        : > "$COLLECTIONS_CONF"
    fi

    printf 'Removed collection: %s\n' "$name"
    printf 'Note: cached data in %s/%s/ was not removed.\n' "$COLLECTIONSDIR" "$name"
}

cmd_collection_list() {
    local found=0
    local -A seen=()

    local conf label
    for conf in "$COLLECTIONS_CONF" "$COLLECTIONS_LIST"; do
        [[ -f "$conf" && -r "$conf" ]] || continue
        if [[ "$conf" == "$COLLECTIONS_CONF" ]]; then
            label="user"
        else
            label="default"
        fi
        while IFS= read -r name; do
            [[ -z "$name" || "$name" == \#* ]] && continue
            [[ -n "${seen[$name]:-}" ]] && continue
            seen[$name]=1
            found=1
            local cached="no"
            [[ -d "${COLLECTIONSDIR}/${name}/.git" ]] && cached="cached"
            local pkg_count=0
            if [[ "$cached" == "cached" ]]; then
                local subdir
                for subdir in "${COLLECTIONSDIR}/${name}"/*/; do
                    [[ -f "${subdir}Makefile" ]] && pkg_count=$((pkg_count + 1))
                done
            fi
            printf '%-28s [%s] [%s] %d package(s)\n' "$name" "$label" "$cached" "$pkg_count"
        done < "$conf"
    done

    [[ $found -eq 1 ]] || echo "No collections configured. Use 'gitpkg collection-add <name>'."
}

# ── Search ────────────────────────────────────────────────

cmd_search() {
    local query="${1:-}"
    [[ -n "$query" ]] || die "usage: gitpkg search <query>"

    local found=0

    # Search pkglist
    if [[ -f "$PKGLIST" && -r "$PKGLIST" ]]; then
        while IFS='|' read -r pname pdesc; do
            [[ -z "$pname" || "$pname" == \#* ]] && continue
            if printf '%s %s' "$pname" "$pdesc" | grep -qi -- "$query"; then
                found=1
                printf '%-28s %s\n' "$pname" "$pdesc"
            fi
        done < "$PKGLIST"
    fi

    # Search cached collections
    local -a collections=()
    mapfile -t collections < <(_load_collections)
    local coll
    for coll in "${collections[@]}"; do
        local colldir="${COLLECTIONSDIR}/${coll}"
        [[ -d "$colldir" ]] || continue
        local subdir
        for subdir in "${colldir}"/*/; do
            [[ -f "${subdir}Makefile" ]] || continue
            local pkgname
            pkgname=$(basename "$subdir")
            if printf '%s' "$pkgname" | grep -qi -- "$query"; then
                found=1
                printf '%-28s (collection: %s)\n' "$pkgname" "$coll"
            fi
        done
    done

    [[ $found -eq 1 ]] || printf 'No packages matching %s.\n' "'${query}'"
}

# ── Signer commands ────────────────────────────────────

cmd_signer_add() {
    local principal="${1:-}"
    local pubkey="${*:2}"

    [[ -n "$principal" ]] || die "usage: gitpkg signer-add <principal> <ssh-pubkey>"
    [[ -n "$pubkey" ]]    || die "usage: gitpkg signer-add <principal> <ssh-pubkey>"
    [[ $EUID -eq 0 ]]     || die "must run as root"

    # Validate key format
    [[ "$pubkey" =~ ^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp[0-9]+|sk-ssh-ed25519@openssh\.com|sk-ecdsa-sha2-nistp256@openssh\.com)[[:space:]] ]] \
        || die "invalid SSH public key format: must start with key type (ssh-ed25519, ssh-rsa, ...)"

    _ensure_conf

    local entry="${principal} ${pubkey}"

    if grep -qF "$principal" "$SIGNERS_CONF" 2>/dev/null; then
        die "signer already added: ${principal}"
    fi

    if [[ -f "$SIGNERS_DEFAULT" ]] && grep -qF "$principal" "$SIGNERS_DEFAULT" 2>/dev/null; then
        die "signer already exists in default keyring: ${principal}"
    fi

    echo "$entry" >> "$SIGNERS_CONF"
    printf 'Added signer: %s\n' "$principal"
}

cmd_signer_del() {
    local principal="${1:-}"
    [[ -n "$principal" ]] || die "usage: gitpkg signer-del <principal>"
    [[ $EUID -eq 0 ]]     || die "must run as root"

    if [[ -f "$SIGNERS_DEFAULT" ]] && grep -q "^${principal} " "$SIGNERS_DEFAULT" 2>/dev/null; then
        die "cannot remove default signer '${principal}' — edit ${SIGNERS_DEFAULT} manually"
    fi

    if [[ ! -f "$SIGNERS_CONF" ]] || ! grep -q "^${principal} " "$SIGNERS_CONF" 2>/dev/null; then
        die "signer not found: ${principal}"
    fi

    local content
    content=$(grep -v "^${principal} " "$SIGNERS_CONF" || true)
    if [[ -n "$content" ]]; then
        printf '%s\n' "$content" > "$SIGNERS_CONF"
    else
        : > "$SIGNERS_CONF"
    fi

    printf 'Removed signer: %s\n' "$principal"
}

cmd_signer_list() {
    local found=0
    local -A seen=()

    local conf label
    for conf in "$SIGNERS_CONF" "$SIGNERS_DEFAULT"; do
        [[ -f "$conf" && -r "$conf" ]] || continue
        if [[ "$conf" == "$SIGNERS_CONF" ]]; then
            label="user"
        else
            label="default"
        fi
        while IFS= read -r line; do
            [[ -z "$line" || "$line" == \#* ]] && continue
            local principal
            principal="${line%% *}"
            [[ -n "${seen[$principal]:-}" ]] && continue
            seen[$principal]=1
            found=1
            local keytype
            keytype=$(awk '{print $2}' <<< "$line")
            printf '%-32s %-20s [%s]\n' "$principal" "$keytype" "$label"
        done < "$conf"
    done

    [[ $found -eq 1 ]] || echo "No signers configured. Use 'gitpkg signer-add <principal> <ssh-pubkey>'."
}

# ── Entry point ───────────────────────────────────────────

case "${1:-}" in
    -h|--help)    show_help ;;
    -V|--version) echo "gitpkg v${VERSION}"; exit 0 ;;
esac

COMMAND="${1:-}"
[[ -n "$COMMAND" ]] || show_help
shift

DRY_RUN=0
YES=0
FIX=0
SKIP_INSPECT=0
NEEDED=0
NODEPS=0
NOSIG=0
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--dry-run)    DRY_RUN=1; shift ;;
        -y|--yes)        YES=1; shift ;;
        --fix)           FIX=1; shift ;;
        --skip-inspect)  SKIP_INSPECT=1; shift ;;
        --needed)        NEEDED=1; shift ;;
        --nodeps)        NODEPS=1; shift ;;
        --nosig)         NOSIG=1; shift ;;
        -h|--help)       show_help ;;
        -*)              die "unknown option: $1" ;;
        *)               ARGS+=("$1"); shift ;;
    esac
done

case "$COMMAND" in
    install)         cmd_install "$DRY_RUN" "$SKIP_INSPECT" "$NEEDED" "$NODEPS" "$NOSIG" ${ARGS[@]+"${ARGS[@]}"} ;;
    update)          cmd_update "$DRY_RUN" "$SKIP_INSPECT" "$NODEPS" "$NOSIG" ${ARGS[@]+"${ARGS[@]}"} ;;
    remove)          cmd_remove "$DRY_RUN" "$YES" "$NODEPS" "${ARGS[0]:-}" ;;
    list)            cmd_list ;;
    status)          cmd_status ;;
    files)           cmd_files "${ARGS[0]:-}" ;;
    inspect)         cmd_inspect "${ARGS[0]:-}" "${ARGS[1]:-}" ;;
    verify)          cmd_verify "$FIX" "${ARGS[0]:-}" ;;
    repo-add)        cmd_repo_add "${ARGS[0]:-}" ;;
    repo-del)        cmd_repo_del "${ARGS[0]:-}" ;;
    repo-list)       cmd_repo_list ;;
    collection-add)  cmd_collection_add "${ARGS[0]:-}" ;;
    collection-del)  cmd_collection_del "${ARGS[0]:-}" ;;
    collection-list) cmd_collection_list ;;
    signer-add)      cmd_signer_add ${ARGS[@]+"${ARGS[@]}"} ;;
    signer-del)      cmd_signer_del "${ARGS[0]:-}" ;;
    signer-list)     cmd_signer_list ;;
    search)          cmd_search "${ARGS[0]:-}" ;;
    *)               die "unknown command: $COMMAND" ;;
esac
